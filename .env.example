# Copy this file to .env.local for local development, and set the same
# variables in the Vercel project's Environment Variables settings for
# Production/Preview. The production build fails immediately if any of the
# non-NEXT_PUBLIC_ variables below are missing (src/utils/env.server.ts).

# Site
NEXT_PUBLIC_SITE_URL=https://www.grameleducation.com
NEXT_PUBLIC_BASE_URL=https://www.grameleducation.com

# Database (Postgres connection string)
DATABASE_URL=

# hCaptcha (https://dashboard.hcaptcha.com)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=

# Cloudinary (https://console.cloudinary.com)
CLOUDINARY_CLOUD_NAME=dqeqlgygu
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# better-auth (any long random string, e.g. `openssl rand -base64 32`)
BETTER_AUTH_SECRET=

# ApplyBoard partner embed
NEXT_PUBLIC_APPLYBOARD_PARTNER_ID=

# Sanity CMS (https://www.sanity.io/manage) - required for /assist and /studio
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
