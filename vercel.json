{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "assist.grameleducation.com" }],
      "destination": "/assist"
    },
    {
      "source": "/:path((?!api|_next|.*\\..*|editor).*)",
      "has": [{ "type": "host", "value": "assist.grameleducation.com" }],
      "destination": "/assist/:path"
    }
  ]
}
